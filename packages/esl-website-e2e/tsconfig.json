{
  "compilerOptions": {
    "esModuleInterop": true,
    "allowJs": true,
    "strict": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": false,
    "noImplicitAny": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "alwaysStrict": true,
    "target": "ESNext",
    "module": "ES2022",
    "moduleResolution": "Node",
    "strictFunctionTypes": true
  }
}
