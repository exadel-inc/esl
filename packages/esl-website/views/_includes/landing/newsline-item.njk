{% macro newsitem(item, index, cls) %}
  <li class="esl-animate-slide up newsline-item {{ cls or '' }}"
      esl-animate="{group: true}">
    {% if item.data.link or isArticle %}
      <a class="newsline-link"
         aria-labelledby="newsline-item-{{ index }}"
         href="{{ item.data.link or (item.url | url) }}"></a>
    {% endif %}
    <div id="newsline-item-{{ index }}" class="newsline-content">
      {% if env.isE2E %}
        <h3 class="newsline-content-title">{{ item.data.title or item.data.name }}</h3>
      {% else %}
        <h3 class="newsline-content-title"
            esl-d-new-label="{{ item.date.getTime() }}">{{ item.data.title or item.data.name }}</h3>
      {% endif %}

      {% if index > 1 %}
        <div class="newsline-content-text markdown-container"
             esl-line-clamp="5 | @+SM => 3">{{ item.templateContent | safe }}</div>
      {% else %}
        <div class="newsline-content-text markdown-container"
             esl-line-clamp="12 | @+SM => 8">{{ item.templateContent | safe }}</div>
      {% endif %}

      <button type="button"
              class="newsline-ctrl link"
              esl-line-clamp-toggler="::prev">
        Read More
      </button>

      {% if item.data.date %}
        <time class="newsline-content-date" datetime="{{ item.date.toISOString() }}">{{ item.date | date }}</time>
      {% endif %}
    </div>
  </li>
{% endmacro %}
