---
layout: content
title: ESL Match Height Mixin
seoTitle: Equalize element heights in rows using ESL Match Height mixin
name: Match Height
tags: [examples, beta]
aside:
  components:
    - esl-match-height
---

<section class="row">
  <div class="col-12">
    <uip-root class="uip-theme-esl">
      <script type="text/html"
              label="ESLMatchHeightMixin"
              uip-snippet
              uip-isolated
              uip-snippet-js="js-snippet-match-height"
              uip-resizable>
        <ul class="simple-grid" style="padding: 10px; margin: 0;" esl-match-height=".card-image, .card-title, .card-desc">

          <li class="simple-grid-cell">
            <div class="card">
              <div class="card-image img-container mb-2" esl-image-container>
                <img class="card-img"
                     alt="volcano"
                     src="{{ '/assets/nature/volcano.jpg' | url }}"
                     height="150"/>
              </div>
              <div class="card-title">
                <h3 class="text-center">First Card</h3>
              </div>
              <div class="card-desc">
                <p><!--text 20--></p>
              </div>
            </div>
          </li>
          <li class="simple-grid-cell">
            <div class="card">
              <div class="card-image img-container mb-2" esl-image-container>
                <img class="card-img"
                     alt="forest"
                     src="{{ '/assets/nature/forest+clouds.jpg' | url }}"
                     height="200"/>
              </div>
              <div class="card-title">
                <h3 class="text-center">Card 2 Short Title</h3>
              </div>
              <div class="card-desc">
                <p><!--text 50--></p>
              </div>
            </div>
          </li>
          <li class="simple-grid-cell">
            <div class="card">
              <div class="card-image img-container mb-2" esl-image-container>
                <img class="card-img"
                     alt="volcano"
                     src="{{ '/assets/nature/volcano.jpg' | url }}"
                     height="180"/>
              </div>
              <div class="card-title">
                <h3 class="text-center">Card 3 Long Long Long title to test match height</h3>
              </div>
              <div class="card-desc">
                <p><!--text 30--></p>
              </div>
            </div>
          </li>
          <li class="simple-grid-cell">
            <div class="card">
              <div class="card-image img-container mb-2" esl-image-container>
                <img class="card-img"
                     alt="forest"
                     src="{{ '/assets/nature/forest+clouds.jpg' | url }}"
                     height="120"/>
              </div>
              <div class="card-title">
                <h3 class="text-center">Last Card</h3>
              </div>
              <div class="card-desc">
                <p><!--text 100--></p>
              </div>
            </div>
          </li>
        </ul>
      </script>

      <script id="js-snippet-match-height" type="text/plain">
        import { ESLMatchHeightMixin } from '@exadel/esl';
        ESLMatchHeightMixin.register();
      </script>

      <uip-snippets class="uip-toolbar" dropdown-view="@xs"></uip-snippets>
      <uip-preview></uip-preview>
      <uip-editor></uip-editor>
      <uip-editor source="js" collapsed></uip-editor>
    </uip-root>
  </div>
</section>
