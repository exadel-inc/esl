{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "esl-website",
  "projectType": "application",
  "targets": {
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rimraf dist",
        "cwd": "packages/esl-website"
      }
    },

    "start": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "esl-website:build:assets"
      ],
      "options": {
        "commands": [
          "nx run esl-website:run:eleventy",
          "nx run esl-website:watch:assets"
        ],
        "parallel": true,
        "cwd": "packages/esl-website"
      }
    },
    "run": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "esl-website:build:assets"
      ],
      "options": {
        "command": "nx run esl-website:run:eleventy",
        "cwd": "packages/esl-website"
      }
    },
    "run:eleventy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eleventy --serve --incremental",
        "cwd": "packages/esl-website"
      }
    },

    "build": {
      "executor": "nx:noop",
      "dependsOn": [
        "esl-website:build:assets",
        "esl-website:build:eleventy"
      ]
    },
    "build:eleventy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eleventy",
        "cwd": "packages/esl-website"
      },
      "dependsOn": ["^build:docs"],
      "cache": true,
      "inputs": [
        {"env": "SITE_ENV"},
        {"input": "default", "projects": ["esl"]},
        "{projectRoot}/11ty/**/*",
        "{projectRoot}/src/**/*",
        "{projectRoot}/views/**/*",
        "{projectRoot}/.eleventy.js"
      ],
      "outputs": [
        "{projectRoot}/dist/**/*"
      ]
    },

    "build:assets": {
      "executor": "nx:noop",
      "dependsOn": [
        "esl:build",
        "uip:build",
        "esl-website:build:skills",
        "esl-website:build:ts",
        "esl-website:build:less"
      ]
    },
    "watch:assets": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run esl:watch",
          "nx run uip:watch",
          {"command": "nx run esl-website:watch:skills", "prefix": "[Site watch:skills]"},
          {"command": "nx run esl-website:watch:ts", "prefix": "[Site watch:ts]"},
          {"command": "nx run esl-website:watch:less", "prefix": "[Site watch:less]"}
        ]
      }
    },

    "build:skills": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npx mkdirp \"dist/downloads\"",
          "tar -czf \"dist/downloads/exadel-esl-ai-skill.tgz\" -C \"../esl/skills\" \"esl\""
        ],
        "parallel": false,
        "cwd": "packages/esl-website"
      },
      "cache": true,
      "inputs": [
        {"input": "default", "projects": ["esl"]}
      ],
      "outputs": [
        "{projectRoot}/dist/downloads/exadel-esl-ai-skill.tgz"
      ]
    },
    "watch:skills": {
      "executor": "nx:run-commands",
      "options": {
        "command": "chokidar \"../esl/skills/**/*.md\" -c \"nx run esl-website:build:skills\"",
        "cwd": "packages/esl-website"
      }
    },

    "build:ts": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "rimraf -g \"dist/**/*.js\"",
          "rspack --mode=production"
        ],
        "parallel": false,
        "cwd": "packages/esl-website"
      },
      "cache": true,
      "dependsOn": ["^build:ts"],
      "inputs": [
        {"env": "SITE_ENV"},
        {"input": "default", "projects": ["esl"]},
        "{projectRoot}/src/**/*.ts",
        "{projectRoot}/rspack.config.js"
      ],
      "outputs": [
        "{projectRoot}/dist/**/*.{js,ts}"
      ]
    },
    "watch:ts": {
      "executor": "nx:run-commands",
      "options": {
        "command": "rspack --watch",
        "cwd": "packages/esl-website"
      }
    },
    "build:ts:analyze": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "rimraf -g \"dist/**/*.js\" report",
          "rspack --mode=production"
        ],
        "parallel": false,
        "env": {
          "RSDOCTOR": "true"
        },
        "cwd": "packages/esl-website"
      },
      "dependsOn": ["^build:ts"]
    },

    "build:less": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx run esl-website:build:less:only",
        "cwd": "packages/esl-website"
      },
      "dependsOn": ["^build:css"]
    },
    "build:less:only": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "rimraf -g \"dist/**/*.css\"",
          "job-ripper \"src/*.less\" -w worker/less.mjs -c 2"
        ],
        "parallel": false,
        "cwd": "packages/esl-website"
      },
      "cache": true,
      "inputs": [
        {"env": "SITE_ENV"},
        {"input": "default", "projects": ["esl", "uip"]},
        "{projectRoot}/.browserslistrc",
        "{projectRoot}/src/**/*.css",
        "{projectRoot}/src/**/*.less"
      ],
      "outputs": [
        "{projectRoot}/dist/bundles/**/*.css"
      ]
    },
    "watch:less": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nodemon",
        "args": [
          "--on-change-only",
          "--watch \"packages/esl/modules\"",
          "--watch \"packages/ui-playground/dist\"",
          "--watch \"packages/esl-website/src\"",
          "--ext css,less",
          "--delay 0.5",
          "--exec \"nx run esl-website:build:less:only\""
        ]
      }
    },

    "lint": {
      "executor": "nx:noop",
      "dependsOn": ["lint:eslint", "lint:stylelint"]
    },
    "lint:stylelint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "stylelint \"src/**/*.(less|css)\"",
        "cwd": "packages/esl-website"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.less",
        "{projectRoot}/src/**/*.css",
        "{projectRoot}/.stylelint.yml"
      ]
    }
  }
}
