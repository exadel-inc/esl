{
  "compilerOptions": {
    "rootDir": "src",
    "declaration": true,
    "skipLibCheck": true,
    "strictPropertyInitialization": false,
    "experimentalDecorators": true,
    "alwaysStrict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "target": "ES6",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "strictFunctionTypes": true
  },
  "include": [
    "src"
  ]
}
